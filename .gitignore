# Velocidad .gitignore
#
# This is the public engine. Personal learner state should never be committed here —
# it belongs in your own data directory (see docs/LEARNER-DATA-SPEC.md). The blank SRS
# box templates that ship with each study ARE committed; your own review state is not.

# Personal path configuration (points at your learner-data directory)
config/paths.yaml

# Personal learner state, per study
*/sessions/2*/
*/srs/.last-review.json
*/srs/.review-history.jsonl
*/meta/learning-observations.md
progress/

# Python
__pycache__/
*.py[cod]
venv/
.venv/
.env

# Editor / OS
.DS_Store
.vscode/
*.swp
